# ── AWD Monitoring — Backend environment ─────────────────────────────
# Salin file ini menjadi `.env` lalu isi nilainya. Jangan commit `.env`.

# Server Flask
HOST=0.0.0.0
PORT=5000
FLASK_DEBUG=0

# Path file database SQLite (relatif terhadap folder backend)
DATABASE_PATH=awd.db

# Telegram Bot (opsional — kosongkan untuk menonaktifkan notifikasi)
# Token dari @BotFather, chat id dari @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=false
